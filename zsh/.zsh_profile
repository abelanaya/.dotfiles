export XDG_CONFIG_HOME=$HOME/.config
VIM="nvim"

#PERSONAL=$XDG_CONFIG_HOME/personal

# Personal alias
alias ll='ls -lAFhrt'
alias li='ls -lAFhrti'
alias l='ls -lAFhrtn'
alias v='nvim'

# Source Cargo env if it exists
[[ -f $HOME/.cargo/env ]] && source $HOME/.cargo/env

# Set up fzf key bindings and fuzzy completion
source <(fzf --zsh)

# Use these sources if installed with clone
#source ~/.fzf/shell/key-bindings.zsh
#source ~/.fzf/shell/completion.zsh

# Configure Bat
export BAT_THEME=TwoDark

export GIT_EDITOR=vim

# Path config
export PATH=$PATH:$HOME/.local/bin:$HOME/.local/scripts

# Bind Tmux sessionizer to Ctrl-f when out of tmux
bindkey -s ^f "$HOME/.local/scripts/tmux-sessionizer.sh\n"

# Enable natural scrolling
if [[ -z xinput ]]; then
    xinput set-prop "ELAN06FA:00 04F3:31AD Touchpad" "libinput Natural Scrolling Enabled" 1
fi

# Functions
eval "$(gh copilot alias -- zsh)"

if [[ -z $STOW_FOLDERS ]]; then
    export STOW_FOLDERS="git,i3,nvim,tmux,zsh,rofi,kitty,dunst,scripts,polybar,Xresources,Gtkrc,fonts,neofetch,prettier,ghostty,karabiner,aerospace"
fi

if [[ -z $DOTFILES ]]; then
    export DOTFILES=$HOME/.dotfiles
fi

function fdf {
    fzf --preview="bat --color=always {}"
}

# Automatically load and unload variables when you cd to folders with .envrc file. For example .envrc file with layout
# python3 will auto create a venv for that folder that is only active while you are on that folder
eval "$(direnv hook zsh)"
#
# Source NVM (Node Version Manager)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# pnpm global store paths
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end
# bun completions
[ -s "~/.bun/_bun" ] && source "~/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# opencode
export PATH=~/.opencode/bin:$PATH
